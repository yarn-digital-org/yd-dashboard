From 9abec955d10d59839746907c8200f124fd401283 Mon Sep 17 00:00:00 2001
From: Yarn Digital <hello@yarndigital.co.uk>
Date: Wed, 11 Mar 2026 21:59:09 +0000
Subject: [PATCH 4/7] feat: Slack inter-agent messaging API

- POST /api/agents/message - send message from any agent to another or all
- GET /api/agents/message - retrieve recent inter-agent messages
- Auto-tags recipient agent via Slack userId when targeting specific agent
- Falls back to log-only if SLACK_BOT_TOKEN not set
- Agent/channel map covers all 6 agents + Jarvis
- Consolidates 'Build Slack Inter-Agent Messaging' + 'Slack Inter-Agent Communication'
---
 yd-dashboard/pages/api/agents/message.js | 122 +++++++++++++++++++++++
 1 file changed, 122 insertions(+)
 create mode 100644 yd-dashboard/pages/api/agents/message.js

diff --git a/yd-dashboard/pages/api/agents/message.js b/yd-dashboard/pages/api/agents/message.js
new file mode 100644
index 0000000..036df00
--- /dev/null
+++ b/yd-dashboard/pages/api/agents/message.js
@@ -0,0 +1,122 @@
+// Inter-agent Slack messaging API
+// POST /api/agents/message — send a message from one agent to another (or to #all-hands)
+// GET  /api/agents/message — get recent inter-agent messages
+
+const SLACK_TOKEN = process.env.SLACK_BOT_TOKEN;
+
+// Agent → Slack channel/user mappings
+const AGENT_CHANNELS = {
+  Bolt:   { channelId: 'C0AKCHQ2WKY', userId: 'U0AKGDJSVEG' }, // #all-hands default
+  Aria:   { channelId: 'C0AKCHQ2WKY', userId: 'U0AKGC1AW20' },
+  Scout:  { channelId: 'C0AKCHQ2WKY', userId: 'U0AKRNBKDAM' },
+  Radar:  { channelId: 'C0AKCHQ2WKY', userId: 'U0AKRR5MGG1' },
+  Blaze:  { channelId: 'C0AKCHQ2WKY', userId: 'U0AKUJ4MWFK' },
+  Jarvis: { channelId: 'C0AKCHQ2WKY', userId: 'U0AC3C0P8AZ' },
+};
+
+const ALL_HANDS_CHANNEL = 'C0AKCHQ2WKY';
+
+// In-memory store for recent messages (would use Firestore in production)
+const messageLog = [];
+
+export default async function handler(req, res) {
+  if (req.method === 'POST') {
+    const { from, to, message, channel } = req.body;
+
+    if (!from || !message) {
+      return res.status(400).json({ error: 'Missing required fields: from, message' });
+    }
+
+    const fromAgent = AGENT_CHANNELS[from];
+    if (!fromAgent) {
+      return res.status(400).json({ error: `Unknown agent: ${from}` });
+    }
+
+    // Build Slack message with proper agent mention
+    let slackMessage = message;
+
+    // If targeting a specific agent, tag them
+    if (to && to !== 'all' && AGENT_CHANNELS[to]) {
+      const toUserId = AGENT_CHANNELS[to].userId;
+      slackMessage = `<@${toUserId}> — ${message}`;
+    }
+
+    // Determine target channel
+    const targetChannel = channel || ALL_HANDS_CHANNEL;
+
+    // Log the message
+    const logEntry = {
+      id: Date.now().toString(),
+      from,
+      to: to || 'all',
+      message,
+      timestamp: new Date().toISOString(),
+      channel: targetChannel,
+      sent: false,
+      slackTs: null,
+    };
+
+    // Send via Slack API if token available
+    if (SLACK_TOKEN) {
+      try {
+        const slackRes = await fetch('https://slack.com/api/chat.postMessage', {
+          method: 'POST',
+          headers: {
+            'Authorization': `Bearer ${SLACK_TOKEN}`,
+            'Content-Type': 'application/json',
+          },
+          body: JSON.stringify({
+            channel: targetChannel,
+            text: slackMessage,
+          }),
+        });
+
+        const slackData = await slackRes.json();
+        if (slackData.ok) {
+          logEntry.sent = true;
+          logEntry.slackTs = slackData.ts;
+        } else {
+          logEntry.error = slackData.error;
+        }
+      } catch (err) {
+        logEntry.error = err.message;
+      }
+    } else {
+      // No Slack token - log only (useful for testing)
+      logEntry.sent = false;
+      logEntry.error = 'No SLACK_BOT_TOKEN configured';
+    }
+
+    messageLog.push(logEntry);
+    // Keep only last 100 messages in memory
+    if (messageLog.length > 100) messageLog.shift();
+
+    return res.status(200).json({
+      success: true,
+      messageId: logEntry.id,
+      sent: logEntry.sent,
+      ...(logEntry.error && { warning: logEntry.error }),
+    });
+  }
+
+  if (req.method === 'GET') {
+    const { from, to, limit = 20 } = req.query;
+
+    let filtered = [...messageLog];
+    if (from) filtered = filtered.filter(m => m.from === from);
+    if (to) filtered = filtered.filter(m => m.to === to || m.to === 'all');
+
+    // Most recent first
+    filtered.reverse();
+    filtered = filtered.slice(0, parseInt(limit));
+
+    return res.status(200).json({
+      success: true,
+      messages: filtered,
+      total: filtered.length,
+    });
+  }
+
+  res.setHeader('Allow', ['GET', 'POST']);
+  res.status(405).end(`Method ${req.method} Not Allowed`);
+}
