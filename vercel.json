{
  "framework": "nextjs",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=4096' npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": ["lhr1"],
  "crons": [
    {
      "path": "/api/cron/invoice-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/calendar-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/automation-triggers",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/drive-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/blog-publish",
      "schedule": "0 21 * * *"
    }
  ]
}

